# Keep the Docker build context small and hermetic: the image installs deps and
# builds INSIDE the container, so host artifacts must never be copied in.

# Dependencies — reinstalled in the deps stage from the lockfile.
**/node_modules
.pnp
.pnp.js
.pnpm-store

# Build outputs — regenerated by `pnpm build` in the builder stage.
**/.next
**/out
**/build
**/dist
**/.turbo

# Local env + secrets — injected at RUN time via --env-file / -e, NEVER baked in.
**/.env
**/.env.*

# Local databases (libSQL/SQLite) — never ship a dev DB.
**/*.db
**/*.db-*
**/local.db
**/local.db-*

# Testing / reports.
**/coverage
**/playwright-report
**/test-results
**/blob-report
**/.playwright
**/playwright/.cache

# VCS / CI / editor / docs — not needed to build or run the server.
.git
.github
.vscode
.idea
**/*.md
.claude
.mcp.json

# Docker's own files.
Dockerfile
.dockerignore

# OS noise.
.DS_Store
**/*.pem
npm-debug.log*
