# Copy to `.env` and fill in. Validated by `@repo/env` at build/startup —
# a missing or malformed required value fails fast (set SKIP_ENV_VALIDATION=true
# to bypass for secret-less CI builds).

# Better Auth
# Generate a strong secret: `openssl rand -base64 32` (must be >= 32 chars)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Optional: explicit base URL for the browser auth client. Leave unset to use
# same-origin (correct for the default single-app deployment).
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Optional: canonical public origin of the app, used by @repo/seo for the SEO
# metadataBase and absolute sitemap/robots/canonical URLs. Leave unset locally
# (defaults to http://localhost:3000); set it to your real origin in production.
# NEXT_PUBLIC_APP_URL=https://example.com

# Database — Drizzle over libSQL. The SAME client + sqlite dialect drives BOTH a
# local file AND remote Turso; you only change these two vars (see packages/db).
#
# Local (default — a fresh clone runs with zero config). Relative paths resolve
# from apps/web:
DATABASE_URL=file:local.db
#
# Turso (remote, production): point DATABASE_URL at the libsql:// URL from
# `turso db show <db> --url` and set DATABASE_AUTH_TOKEN from
# `turso db tokens create <db>`. The client already forwards the token, so this
# is all that changes — no code edits, same sqlite dialect.
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token
