# Copy to `.env` and fill in. Validated by `@repo/env` at build/startup —
# a missing or malformed required value fails fast (set SKIP_ENV_VALIDATION=true
# to bypass for secret-less CI builds).

# Better Auth
# Generate a strong secret: `openssl rand -base64 32` (must be >= 32 chars)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Optional: comma-separated emails auto-promoted to role "admin" on sign-up
# (bootstrap for the first admin in apps/admin). Leave unset for no env-seeded
# admins; promote an existing user with `pnpm --filter @repo/auth promote-admin`.
# SECURITY: only safe when email verification is ON (i.e. RESEND_API_KEY +
# EMAIL_FROM are set). Without email, an attacker can claim an UNCLAIMED listed
# address and get admin instantly — in that case use `promote-admin` instead.
# ADMIN_EMAILS=you@example.com

# Optional: explicit base URL for the browser auth client. Leave unset to use
# same-origin (correct for the default single-app deployment).
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Optional: canonical public origin of the app, used by @repo/seo for the SEO
# metadataBase and absolute sitemap/robots/canonical URLs. Leave unset locally
# (defaults to http://localhost:3000); set it to your real origin in production.
# NEXT_PUBLIC_APP_URL=https://example.com

# Database — Drizzle over libSQL. The SAME client + sqlite dialect drives BOTH a
# local file AND remote Turso; you only change these two vars (see packages/db).
#
# Local (default — a fresh clone runs with zero config). Relative paths resolve
# from apps/web:
DATABASE_URL=file:local.db
#
# Turso (remote, production): point DATABASE_URL at the libsql:// URL from
# `turso db show <db> --url` and set DATABASE_AUTH_TOKEN from
# `turso db tokens create <db>`. The client already forwards the token, so this
# is all that changes — no code edits, same sqlite dialect.
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# Email — Resend (@repo/email). BOTH are optional: leave them unset and the
# welcome-email send no-ops (logs one warning, never throws), so sign-up still
# works with no email account. Set both to actually deliver mail. Get a key at
# https://resend.com/api-keys; EMAIL_FROM must be a verified sender/domain.
# RESEND_API_KEY=re_your_resend_api_key
# EMAIL_FROM=Shipwright <onboarding@yourdomain.com>

# Analytics — PostHog (@repo/analytics). Optional: leave NEXT_PUBLIC_POSTHOG_KEY
# unset and analytics is a complete no-op (posthog-js never loads), so the app,
# tests, and CI run with no analytics account. Even when set, nothing is captured
# until the user accepts cookies (see @repo/legal consent). When the key IS set,
# the host origin is added to the CSP connect-src automatically (see proxy.ts).
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Observability — Sentry (@repo/observability). ALL optional: leave the DSNs
# unset and Sentry is a complete no-op — the SDK never initialises, the build is
# not instrumented, no source maps are uploaded, and the CSP connect-src is NOT
# broadened — so the app, tests, and CI run with no Sentry account. Set the DSN(s)
# to enable error/perf monitoring; the structured logger in @repo/observability is
# always on regardless. Get a DSN from your Sentry project settings.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Build-time source-map upload (optional): without all three the build still
# succeeds and simply skips upload.
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# Optional traces sample rate (0..1); defaults to 0.1.
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Rate limiting — @repo/security. Optional: with NEITHER var set the limiter uses
# a dependency-free in-memory sliding window (correct for dev/CI/tests and a
# single instance). Set BOTH to use Upstash Redis so the window is SHARED across
# instances in a multi-instance production deployment. Get them from the Upstash
# console (REST API section).
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Billing — Stripe (@repo/payments). ALL optional: leave them unset and billing
# degrades gracefully — the Stripe client is never constructed, the dashboard
# hides the "Upgrade to Pro" button (showing "Billing not configured"), and the
# webhook route answers 503 — so the app, tests, and CI run with no Stripe
# account. Set all three to enable subscriptions.
#   - STRIPE_SECRET_KEY: secret API key from https://dashboard.stripe.com/apikeys
#   - STRIPE_WEBHOOK_SECRET: the signing secret for your webhook endpoint
#     (Developers → Webhooks, or `stripe listen` for local dev). The endpoint is
#     POST /api/stripe/webhook.
#   - STRIPE_PRICE_ID / NEXT_PUBLIC_STRIPE_PRICE_ID: the recurring Price the
#     upgrade button checks out. A price id is not a secret, so the public var is
#     fine; the server reads STRIPE_PRICE_ID first, then the public one.
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# STRIPE_PRICE_ID=price_your_recurring_price_id
# NEXT_PUBLIC_STRIPE_PRICE_ID=price_your_recurring_price_id

# Optional structured-logger minimum level (debug|info|warn|error). Defaults to
# debug in development and info in production.
# LOG_LEVEL=info

# Web Push — VAPID (@repo/pwa). ALL optional: leave them unset and push degrades
# gracefully — the dashboard push toggle is disabled ("Push not configured") and
# the sender no-ops (logs one warning, never throws) — so the app, tests, and CI
# run with no push keys. Generate a keypair with `npx web-push generate-vapid-keys`.
#   - NEXT_PUBLIC_VAPID_PUBLIC_KEY: public key, sent to the browser to subscribe
#     (not a secret).
#   - VAPID_PRIVATE_KEY: private key, signs pushes server-side (keep secret).
#   - VAPID_SUBJECT: a mailto: or https contact URI for the push service.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_vapid_key
# VAPID_PRIVATE_KEY=your_private_vapid_key
# VAPID_SUBJECT=mailto:admin@example.com

# SEO — Google Search Console verification (@repo/seo). Optional: set the token
# from Search Console's "HTML tag" method to emit the verification meta tag.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_search_console_token

# Analytics — Google Analytics 4 (@repo/analytics, coexists with PostHog).
# Optional: leave unset and GA4 no-ops (gtag never loads). Consent-gated even
# when set. Get a Measurement ID (G-XXXXXXXXXX) from a GA4 web data stream.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# OAuth social login — Google + GitHub (@repo/auth). ALL optional: a provider's
# button + server registration appear only when BOTH its clientId and secret are
# set, so the app runs keyless with email/password only. The clientId is public
# (it appears in the OAuth redirect); only the secret is sensitive. Callback URL:
# <BETTER_AUTH_URL>/api/auth/callback/<provider> (e.g. .../api/auth/callback/github).
# NEXT_PUBLIC_GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# File storage — S3-compatible (@repo/storage): Cloudflare R2, AWS S3, MinIO, etc.
# ALL optional: with any unset the dashboard shows "Storage not configured" and
# uploads are disabled, so the app runs with no bucket. R2 example endpoint:
# https://<accountid>.r2.cloudflarestorage.com
# S3_ENDPOINT=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
