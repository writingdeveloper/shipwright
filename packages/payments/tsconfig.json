{
  // react-library (not base): @repo/email's templates are .tsx sources this
  // package's program type-checks transitively, so `jsx` must be set.
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "strictNullChecks": true,
    "noEmit": true,
    "module": "Preserve",
    "moduleResolution": "Bundler"
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist"]
}
